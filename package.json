{
	"name": "srjc-tec-website",
	"version": "0.1.0",
	"description": "Website for The Engineering Club at Santa Rosa Junior College",
	"homepage": "https://github.com/funnbot/srjc-tec-website#readme",
	"bugs": {
		"url": "https://github.com/funnbot/srjc-tec-website/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/funnbot/srjc-tec-website.git"
	},
	"license": "MIT",
	"author": "",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"eslint": "eslint .",
		"scn-add": "deno run -A --node-modules-dir npm:shadcn-svelte@latest add"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.3",
		"@eslint/js": "^10.0.1",
		"@internationalized/date": "^3.12.0",
		"@lucide/svelte": "^0.577.0",
		"@nvl/sveltex": "^0.4.4",
		"@poppanator/sveltekit-svg": "^6.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.1",
		"@types/node": "^25.5.0",
		"bits-ui": "^2.16.3",
		"clsx": "^2.1.1",
		"eslint": "^10.0.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-better-tailwindcss": "^4.3.2",
		"eslint-plugin-svelte": "^3.15.2",
		"globals": "^17.4.0",
		"mode-watcher": "^1.1.0",
		"prettier": "^3.8.1",
		"prettier-plugin-organize-imports": "^4.3.0",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.53.12",
		"svelte-check": "^4.4.5",
		"svelte-eslint-parser": "^1.6.0",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.1",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.1",
		"valibot": "^1.3.1",
		"vite": "^8.0.0"
	}
